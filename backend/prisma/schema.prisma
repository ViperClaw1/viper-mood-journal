// https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

model JournalEntry {
  id         String   @id @default(cuid())
  mood       String
  aiResponse String?
  createdAt  DateTime @default(now())
}
