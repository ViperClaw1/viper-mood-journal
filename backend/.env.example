# Copy to .env and set values. Do not commit .env.

# Required for Claude AI responses. Get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your-anthropic-api-key-from-console-anthropic

# Database connection (Docker: backend uses hostname "postgres", port 5432)
DATABASE_URL="postgresql://postgres:postgres@postgres:5434/mood_journal"

# Server port (default 3000)
PORT=3000

# Production: Vercel frontend URL for CORS (e.g. https://your-app.vercel.app). Omit for local dev.
# FRONTEND_ORIGIN=
