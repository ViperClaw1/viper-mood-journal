# Copy to .env in this directory (backend/.env). Do not commit .env.
# Docker Compose loads backend/.env and overrides DATABASE_URL for the container (see docker-compose.yml).

# -----------------------------------------------------------------------------
# AI (journal reflections)
# -----------------------------------------------------------------------------
# Required for Claude. https://console.anthropic.com/
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
# Local: backend on your machine, Postgres from Docker mapped to localhost:5434
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/mood_journal"
# Inside Docker Compose, DATABASE_URL is set by compose to use host "postgres" — ignore localhost in .env for that case.

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=3000

# -----------------------------------------------------------------------------
# Auth (JWT + cookies)
# -----------------------------------------------------------------------------
# Long random string in production
JWT_SECRET=

# -----------------------------------------------------------------------------
# Google OAuth (optional if you only use email/password)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match the authorized redirect URI in Google Cloud (backend URL + path)
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# -----------------------------------------------------------------------------
# Environment / CORS / public URLs
# -----------------------------------------------------------------------------
# production: enables secure cookies, SameSite=None for cross-site cookie
# NODE_ENV=development

# Comma-separated allowed browser origins (Vercel app, etc.). Local SPA: http://localhost:5173
# FRONTEND_ORIGIN=http://localhost:5173

# Base URL of this API as seen by the browser (avatar links). Local Docker: http://localhost:3000
# Production: https://your-api.up.railway.app (or your custom domain)
# PUBLIC_API_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Password reset email (SMTP; e.g. Resend https://resend.com/docs/send-with-smtp)
# -----------------------------------------------------------------------------
# MAIL_FROM must use a domain verified in your provider (or Resend sandbox for testing).
MAIL_FROM="Mood Journal <onboarding@yourdomain.com>"
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=

# Frontend reset page (no ?). Email appends ?token=...
PASSWORD_RESET_FRONTEND_URL=http://localhost:5173/reset-password
