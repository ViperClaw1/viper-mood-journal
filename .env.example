# Mood Journal — environment template for Docker Compose and local backend
#
# Workflow (recommended): copy this file to backend/.env
#   cp .env.example backend/.env
# Then edit backend/.env with real values.
#
# docker compose reads backend/.env via env_file and sets DATABASE_URL for the
# backend container to postgresql://...@postgres:5432/mood_journal automatically.
# Your DATABASE_URL line in backend/.env can stay on localhost:5434 for running
# the backend on the host with dockerized Postgres only.
#
# Variable names match the Node backend (SMTP_*, not EMAIL_*).

# --- AI ---
ANTHROPIC_API_KEY=

# --- Database (host-run backend; overridden in container by compose) ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/mood_journal"

PORT=3000

# --- JWT ---
JWT_SECRET=

# --- Google OAuth ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# --- Optional ---
# NODE_ENV=development
# FRONTEND_ORIGIN=http://localhost:5173
# PUBLIC_API_URL=http://localhost:3000

# --- Password reset (SMTP) ---
MAIL_FROM="Mood Journal <onboarding@yourdomain.com>"
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USER=resend
SMTP_PASS=
PASSWORD_RESET_FRONTEND_URL=http://localhost:5173/reset-password
